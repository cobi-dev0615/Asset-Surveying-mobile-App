<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash theme using AndroidX SplashScreen compat library -->
    <style name="Theme.SERInventarios.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/black</item>
        <item name="postSplashScreenTheme">@style/Theme.SERInventarios</item>
    </style>

    <!-- Main app theme (Compose takes over) -->
    <style name="Theme.SERInventarios" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">#FFF8F9FA</item>
    </style>
</resources>
